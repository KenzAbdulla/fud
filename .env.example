# ─── Swiggy MCP OAuth ────────────────────────────────────────────────────────
SWIGGY_CLIENT_ID=
# Exact-match redirect URI (HTTPS in prod; http://localhost:3000 allowed for dev)
SWIGGY_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ─── Supabase (Mumbai ap-south-1) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Upstash Redis (Mumbai/Singapore) ────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── LLM — recipe extraction ─────────────────────────────────────────────────
# Gemini 2.5 Flash preferred (APAC endpoint for DPDP residency)
GOOGLE_GENERATIVE_AI_API_KEY=
# OpenAI fallback (GPT-4o-mini tier)
OPENAI_API_KEY=

# ─── Groq — Whisper transcription ────────────────────────────────────────────
GROQ_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 32-byte hex secret for encrypting stored tokens at rest
TOKEN_ENCRYPTION_SECRET=

# ─── Dev flags ───────────────────────────────────────────────────────────────
# Set to "true" to use fixture JSON instead of live MCP calls
USE_MCP_FIXTURES=false
